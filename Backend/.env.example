# Copy to Backend/.env or project root .env and fill in values.
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
CAREGIVER_WHATSAPP=whatsapp:+91XXXXXXXXXX
PATIENT_NAME=Patient Name
PATIENT_ADDRESS=Patient Home Address Here

# When true, alert endpoints log to console instead of 503 if Twilio is missing
ICOMM_DEV_MODE=true
