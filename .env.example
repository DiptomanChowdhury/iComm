# Frontend → backend URLs (copy to .env and adjust per environment)
# Used by Electron preload and by tools that load process.env before the UI runs.

# Local dev (default — same machine as Python backends)
ICOMM_API_URL=http://localhost:8000
ICOMM_GAZE_WS_URL=ws://localhost:8765

# Must match Backend/calibration.py SCREEN_W and SCREEN_H
ICOMM_SCREEN_W=1920
ICOMM_SCREEN_H=1080

# Example: live / deployed backends on another host
# ICOMM_API_URL=https://alerts.yourdomain.com
# ICOMM_GAZE_WS_URL=wss://gaze.yourdomain.com
